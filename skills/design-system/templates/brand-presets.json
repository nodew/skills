      "400": "#9CA3AF", "500": "#6B7280", "600": "#4B5563", "700": "#374151",
      "800": "#1F2937", "900": "#111827", "950": "#030712"
    },
    "cool-gray": {
      "50": "#F9FAFB", "100": "#F3F4F6", "200": "#E5E7EB", "300": "#D1D5DB",
      "400": "#9CA3AF", "500": "#6B7280", "600": "#4B5563", "700": "#374151",
      "800": "#1F2937", "900": "#111827", "950": "#030712"
    },
    "warm-gray": {
      "50": "#FAFAF9", "100": "#F5F5F4", "200": "#E7E5E4", "300": "#D6D3D1",
      "400": "#A8A29E", "500": "#78716C", "600": "#57534E", "700": "#44403C",
      "800": "#292524", "900": "#1C1917", "950": "#0C0A09"
    },
    "slate": {
      "50": "#F8FAFC", "100": "#F1F5F9", "200": "#E2E8F0", "300": "#CBD5E1",
      "400": "#94A3B8", "500": "#64748B", "600": "#475569", "700": "#334155",
      "800": "#1E293B", "900": "#0F172A", "950": "#020617"
    },
    "zinc": {
      "50": "#FAFAFA", "100": "#F4F4F5", "200": "#E4E4E7", "300": "#D4D4D8",
      "400": "#A1A1AA", "500": "#71717A", "600": "#52525B", "700": "#3F3F46",
      "800": "#27272A", "900": "#18181B", "950": "#09090B"
    }
  },
  "radiusMap": {
    "none": "0",
    "sm": "0.125rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "full": "9999px"
  },
  "shadowMap": {
    "none": "none",
    "subtle": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "default": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "prominent": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)"
  },
  "densityMap": {
    "tight": { "component": "0.5rem", "section": "1.5rem", "page": "1rem" },
    "standard": { "component": "1rem", "section": "3rem", "page": "1.5rem" },
    "loose": { "component": "1.5rem", "section": "4rem", "page": "2rem" }
  }
}
